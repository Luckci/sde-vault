# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit it.
#
# EMAIL     = your FULL school email / UPN, e.g. madsb@sde.dk or madsb@otg.dk
#             This is the email you type at the Microsoft login page.
#
# PASSWORD  = your AD / school password (same one you use everywhere at school)

EMAIL=madsb@otg.dk
PASSWORD=your_password_here

# ── AI provider credentials ────────────────────────────────────────────────
# Only fill in the key(s) for the provider(s) you want to use.
# Use --ai-provider to pick one at runtime (default: claude).

# Claude (Anthropic) — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# ChatGPT (OpenAI) — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# Gemini (Google) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here
